# ============================================================
#  Sahyatri — Real-time Server Environment Variables
# ============================================================
#
#  INSTRUCTIONS:
#  1. Copy this file to .env (same directory)
#  2. Fill in your actual values below
#  3. Never commit .env to version control
#
# ============================================================

# ── Server ───────────────────────────────────────────────────
# Port the realtime server will run on
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
# Your MongoDB connection URI
# Local: mongodb://localhost:27017/sahyatri
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/sahyatri
MONGODB_URI=mongodb://localhost:27017/sahyatri

# ── JWT Authentication ────────────────────────────────────────
# A long random string used to sign JWT tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ── CORS ─────────────────────────────────────────────────────
# Frontend URL (React dev server)
SOCKET_CORS_ORIGIN=http://localhost:5173

# ── Admin Setup ──────────────────────────────────────────────
# Initial Admin User (Created automatically on startup if not exists)
ADMIN_EMAIL=admin@sahyatri.com
ADMIN_PASSWORD=Admin@123

# SMTP Configuration for sending email alerts to users
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_admin_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your_admin_email@gmail.com
FROM_NAME="Sahyatri Crowd Risk System"


Sahyatri=skpk xtke kxad rwwg

# ── Crowd Simulation ─────────────────────────────────────────
# Interval in ms to push simulated crowd data via WebSocket
CROWD_SIM_INTERVAL_MS=5000
