# ============================================================
#  Sahyatri — Real-time Server — Environment Variables Example
# ============================================================

PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/sahyatri

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS — comma-separated production origins
SOCKET_CORS_ORIGIN=https://<your-vercel-app>.vercel.app,https://<your-vercel-custom-domain>

# Admin
ADMIN_EMAIL=admin@sahyatri.com
ADMIN_PASSWORD=Admin@123

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=Sahyatri Crowd Risk System

# Crowd simulation
CROWD_SIM_INTERVAL_MS=5000
