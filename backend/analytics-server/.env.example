# ============================================================
#  Sahyatri — Analytics Server Environment Variables
# ============================================================
#
#  INSTRUCTIONS:
#  1. Copy this file to .env (same directory)
#  2. Fill in your actual values below
#
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5001

# ── SQLite Database ──────────────────────────────────────────
# Path to SQLite database file (auto-created if missing)
SQLITE_DB_PATH=./sahyatri_analytics.db

# ── JWT ──────────────────────────────────────────────────────
# Must match the same JWT_SECRET used in realtime-server
JWT_SECRET=sahyatri_dev_secret_key_change_in_production

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Data Retention ───────────────────────────────────────────
# How many days of crowd history to keep (older entries will be pruned)
DATA_RETENTION_DAYS=30
