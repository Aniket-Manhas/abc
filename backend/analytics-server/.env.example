# ============================================================
#  Sahyatri — Analytics Server — Environment Variables Example
# ============================================================

PORT=5001

# Production: set DATABASE_URL to use PostgreSQL (Neon/Supabase)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Dev: SQLite fallback
SQLITE_DB_PATH=./sahyatri_analytics.db

# CORS
CORS_ORIGIN=https://<your-vercel-app>.vercel.app

# JWT (for optional auth middleware)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Data retention
DATA_RETENTION_DAYS=30
