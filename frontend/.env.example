# ============================================================
#  Sahyatri — Frontend Environment Variables
# ============================================================
#
#  INSTRUCTIONS:
#  1. Rename this file to .env (same directory)
#  2. Fill in your actual values below
#  3. All VITE_ variables are exposed to the browser
#
# ============================================================

# ── Backend API URLs ─────────────────────────────────────────
# Real-time server (Node.js + MongoDB + Socket.io)
VITE_REALTIME_API_URL=http://localhost:5000

# Analytics server (Express + SQLite)
VITE_ANALYTICS_API_URL=http://localhost:5001

# Socket.io connection URL (usually same as realtime server)
VITE_SOCKET_URL=http://localhost:5000

# ── Map Configuration ─────────────────────────────────────────
# Station center coordinates (New Delhi Railway Station default)
VITE_MAP_DEFAULT_LAT=28.6430
VITE_MAP_DEFAULT_LNG=77.2239
VITE_MAP_DEFAULT_ZOOM=17

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=Sahyatri
