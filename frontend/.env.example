# ============================================================
#  Sahyatri — Frontend Environment Variables
# ============================================================

# ── Backend API URLs ─────────────────────────────────────────
# Production values — set these in Vercel dashboard
VITE_REALTIME_API_URL=https://<your-realtime-render-url>.onrender.com
VITE_ANALYTICS_API_URL=https://<your-analytics-render-url>.onrender.com
VITE_SOCKET_URL=https://<your-realtime-render-url>.onrender.com
VITE_STAMPEDE_URL=https://<your-hf-space>.hf.space

# ── Map Configuration ─────────────────────────────────────────
VITE_MAP_DEFAULT_LAT=28.6430
VITE_MAP_DEFAULT_LNG=77.2239
VITE_MAP_DEFAULT_ZOOM=17

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME=Sahyatri
VITE_GEMINI_API_KEY=your-gemini-key
VITE_GEMINI_NAME="Sahyatri working"
VITE_GEMINI_PROJECT_NAME=projects/<id>
VITE_GEMINI_PROJECT_NUMBER=<id>
