# Replace with your deployed Render service URLs
EXPO_PUBLIC_REALTIME_URL=https://<your-realtime-render-url>.onrender.com
EXPO_PUBLIC_ANALYTICS_URL=https://<your-analytics-render-url>.onrender.com
EXPO_PUBLIC_INDOOR_NAV_URL=https://<your-nav-render-url>.onrender.com

EXPO_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here
