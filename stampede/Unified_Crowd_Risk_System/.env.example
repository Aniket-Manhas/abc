# ============================================================
#  Sahyatri — ML Server — Environment Variables Example
# ============================================================

# Deployment Settings
PORT=7860
FLASK_ENV=production
ANALYTICS_API_URL=https://<your-analytics-render-url>

# Email Alert Settings
ENABLE_EMAIL_ALERTS=False
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=adminSahyatri
ADMIN_ALERT_EMAIL=

# Video Analytics
YOLO_CONF=0.20
P2PNET_THRESHOLD=0.35
DENSE_THRESHOLD=6
ZONE_AREA_M2=50.0

# P2PNet weights auto-download URL (leave blank to skip P2PNet)
P2PNET_WEIGHTS_URL=
